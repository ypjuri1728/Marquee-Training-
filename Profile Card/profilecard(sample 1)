<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profilecart</title>
    <style>
        .main{
            width: 300px;
            height: 400px;
            background-color: rgb(209, 209, 207);
